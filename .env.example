# Copy to .env and fill values
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
# For server-side inserts when Row Level Security (RLS) is enabled, set the service role key here.
# Keep this secret and do NOT expose it to the browser/client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET=payslips
SUPABASE_TABLE=payroll_records
PORT=3000
BREVO_API_KEY=your-brevo-api-key
BREVO_FROM_EMAIL=your-from-email@example.com
GMAIL_USER=your-gmail@example.com
GMAIL_APP_PASSWORD=your-gmail-app-password
EMAIL_FROM_ADDRESS=your-from-email@example.com
ADMIN_AUTH_TOKEN=your-admin-token
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-app.example.com